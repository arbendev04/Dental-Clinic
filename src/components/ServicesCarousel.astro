---
interface Service {
  id: string;
  title: string;
  description: string;
  ctaText: string;
  ctaLink: string;
}

const services: Service[] = [
  {
    id: 'odontologia-digital',
    title: 'Odontología Digital',
    description: 'Escáneres intraorales 3D, diseño de sonrisa digital y planificación quirúrgica virtual para resultados precisos.',
    ctaText: 'Conocer más',
    ctaLink: '/servicios#odontologia-digital'
  },
  {
    id: 'implantologia',
    title: 'Implantología',
    description: 'Implantes de titanio con cirugía guiada por computadora. Técnicas mínimamente invasivas y recuperación acelerada.',
    ctaText: 'Conocer más',
    ctaLink: '/servicios#implantologia'
  },
  {
    id: 'estetica-dental',
    title: 'Estética Dental',
    description: 'Carillas de porcelana, blanqueamiento láser y diseño de sonrisa. Resultados naturales y armoniosos.',
    ctaText: 'Conocer más',
    ctaLink: '/servicios#estetica'
  },
  {
    id: 'rehabilitacion-oral',
    title: 'Rehabilitación Oral',
    description: 'Coronas, puentes y prótesis en zirconia de última generación. Restauración completa de función y estética.',
    ctaText: 'Conocer más',
    ctaLink: '/servicios#rehabilitacion'
  }
];
---

<section class="relative w-full min-h-[700px] py-16 bg-gray-100/80 dark:bg-gray-950 overflow-hidden transition-colors duration-500">
  <!-- Subtle Background -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-gray-50 via-gray-100/80 to-gray-200/60 dark:from-gray-900 dark:via-gray-950 dark:to-black transition-colors duration-500"></div>

  <!-- Section Title -->
  <div class="relative z-10 text-center mb-10">
    <span class="text-gray-600 dark:text-white/40 text-xs tracking-[0.3em] uppercase font-light transition-colors duration-500">Nuestros</span>
    <h2 class="text-3xl md:text-4xl font-extralight text-gray-800 dark:text-white mt-1 tracking-wide transition-colors duration-500">Servicios</h2>
  </div>

  <!-- Carousel Container -->
  <div class="relative flex items-center justify-center">

    <!-- Navigation Arrows (outside card, close to it) -->
    <button
      id="carousel-prev"
      class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 z-30 p-2 text-gray-500 hover:text-gray-800 dark:text-white/25 dark:hover:text-white/70 transition-colors duration-300"
      aria-label="Anterior"
    >
      <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <button
      id="carousel-next"
      class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 z-30 p-2 text-gray-500 hover:text-gray-800 dark:text-white/25 dark:hover:text-white/70 transition-colors duration-300"
      aria-label="Siguiente"
    >
      <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Card Container -->
    <div class="relative w-[70%] max-w-4xl h-[55vh] min-h-[420px]">

      <!-- Cards -->
      {services.map((service, index) => (
        <div
          class={`carousel-card absolute inset-0 transition-all duration-700 ease-out ${index === 0 ? 'opacity-100 scale-100 z-20' : index === 1 ? 'opacity-[0.15] scale-[0.85] translate-x-[85%] z-10' : index === services.length - 1 ? 'opacity-[0.15] scale-[0.85] -translate-x-[85%] z-10' : 'opacity-0 scale-75 z-0'}`}
          data-index={index}
        >
          <!-- Card with Border Glow -->
          <div class="relative h-full rounded-lg overflow-hidden">
            <!-- Animated Border -->
            <div class="absolute -inset-px rounded-lg overflow-hidden">
              <div class="absolute inset-0 border border-gray-300/60 dark:border-white/[0.08] rounded-lg transition-colors duration-500"></div>
              <div class="border-glow absolute w-[200%] h-[200%] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                <div class="absolute inset-0 bg-[conic-gradient(from_0deg,transparent_0%,transparent_70%,rgba(99,102,241,0.4)_80%,rgba(165,180,252,0.6)_85%,rgba(99,102,241,0.4)_90%,transparent_100%)] dark:bg-[conic-gradient(from_0deg,transparent_0%,transparent_70%,rgba(103,232,249,0.4)_80%,rgba(255,255,255,0.6)_85%,rgba(103,232,249,0.4)_90%,transparent_100%)] animate-border-spin"></div>
              </div>
            </div>

            <!-- Card Content -->
            <div class="relative h-full rounded-lg bg-white/95 dark:bg-gray-900/90 backdrop-blur-md shadow-xl shadow-gray-300/50 dark:shadow-none border-2 border-gray-300/80 dark:border-white/10 flex flex-col md:flex-row transition-all duration-500">

              <!-- Left: Visual Area -->
              <div class="relative w-full md:w-[55%] h-[45%] md:h-full flex items-center justify-center p-6 md:p-8">

                {service.id === 'odontologia-digital' && (
                  <svg class="w-full max-w-sm h-auto text-indigo-500/80 dark:text-cyan-400/80 animate-float transition-colors duration-500" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="0.5">
                    <ellipse cx="100" cy="170" rx="50" ry="12" class="opacity-20"/>
                    <rect x="70" y="90" width="60" height="80" rx="4" class="fill-gray-700/30 dark:fill-gray-800/30"/>
                    <rect x="76" y="96" width="48" height="55" rx="2" class="fill-indigo-950/20 dark:fill-cyan-950/30 stroke-indigo-400/40 dark:stroke-cyan-400/40"/>
                    <rect x="82" y="102" width="36" height="43" rx="1" class="fill-gray-800/80 dark:fill-gray-900/80"/>
                    <line x1="86" y1="112" x2="114" y2="112" class="stroke-indigo-500/50 dark:stroke-cyan-400/50 animate-scan-line" stroke-width="1"/>
                    <line x1="86" y1="122" x2="114" y2="122" class="stroke-indigo-500/30 dark:stroke-cyan-400/30 animate-scan-line delay-1" stroke-width="1"/>
                    <line x1="86" y1="132" x2="114" y2="132" class="stroke-indigo-500/50 dark:stroke-cyan-400/50 animate-scan-line delay-2" stroke-width="1"/>
                    <g class="animate-hologram">
                      <path d="M92 55 Q100 38 108 55 Q112 68 108 78 Q100 86 92 78 Q88 68 92 55" class="fill-indigo-400/10 dark:fill-cyan-400/10 stroke-indigo-500/60 dark:stroke-cyan-400/60"/>
                    </g>
                    <path d="M100 82 L100 96" class="stroke-indigo-500/30 dark:stroke-cyan-400/30" stroke-dasharray="3 3"/>
                    <circle cx="100" cy="86" r="2" class="fill-indigo-500/50 dark:fill-cyan-400/50 animate-pulse-dot"/>
                    <circle cx="65" cy="65" r="2" class="fill-indigo-500/30 dark:fill-cyan-400/30 animate-data-point"/>
                    <circle cx="135" cy="72" r="1.5" class="fill-indigo-500/20 dark:fill-cyan-400/20 animate-data-point delay-1"/>
                  </svg>
                )}

                {service.id === 'implantologia' && (
                  <svg class="w-full max-w-sm h-auto text-indigo-500/80 dark:text-cyan-400/80 animate-float-slow transition-colors duration-500" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="0.5">
                    <path d="M50 155 Q80 140 100 140 Q120 140 150 155" class="stroke-gray-600/50 fill-gray-700/20 dark:fill-gray-800/20"/>
                    <g class="animate-implant">
                      <path d="M88 50 Q100 35 112 50 Q116 60 112 70 L88 70 Q84 60 88 50" class="fill-white/10 stroke-indigo-400/60 dark:stroke-cyan-300/60"/>
                      <rect x="93" y="70" width="14" height="12" rx="2" class="fill-gray-600/50 dark:fill-gray-700/50 stroke-indigo-500/50 dark:stroke-cyan-400/50"/>
                      <path d="M96 82 L96 130 M104 82 L104 130" class="stroke-indigo-500/40 dark:stroke-cyan-400/40"/>
                      <path d="M94 92 L106 92 M93 102 L107 102 M94 112 L106 112 M95 122 L105 122" class="stroke-indigo-500/30 dark:stroke-cyan-400/30"/>
                      <path d="M96 130 Q100 138 104 130" class="stroke-indigo-500/40 dark:stroke-cyan-400/40"/>
                    </g>
                    <line x1="100" y1="25" x2="100" y2="42" class="stroke-indigo-500/20 dark:stroke-cyan-400/20 animate-guide" stroke-dasharray="4 4"/>
                    <circle cx="100" cy="25" r="3" class="stroke-indigo-500/30 dark:stroke-cyan-400/30 fill-none animate-marker"/>
                    <g class="opacity-40">
                      <line x1="140" y1="50" x2="140" y2="125" class="stroke-indigo-500/30 dark:stroke-cyan-400/30"/>
                      <line x1="136" y1="50" x2="144" y2="50" class="stroke-indigo-500/30 dark:stroke-cyan-400/30"/>
                      <line x1="136" y1="125" x2="144" y2="125" class="stroke-indigo-500/30 dark:stroke-cyan-400/30"/>
                    </g>
                  </svg>
                )}

                {service.id === 'estetica-dental' && (
                  <svg class="w-full max-w-sm h-auto text-indigo-500/80 dark:text-cyan-400/80 animate-float transition-colors duration-500" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="0.5">
                    <path d="M35 125 Q100 170 165 125" class="stroke-indigo-400/15 dark:stroke-cyan-400/15"/>
                    <g class="animate-smile">
                      <path d="M55 105 Q62 90 72 90 Q82 90 82 105 L82 118 Q77 128 68 128 Q58 128 55 118 Z" class="fill-white/80 stroke-indigo-200/40 dark:stroke-cyan-200/40"/>
                      <path d="M85 100 Q94 82 104 82 Q114 82 117 100 L117 118 Q112 130 101 130 Q90 130 85 118 Z" class="fill-white/85 stroke-indigo-200/40 dark:stroke-cyan-200/40"/>
                      <path d="M120 100 Q129 82 139 82 Q149 82 152 100 L152 118 Q147 130 138 130 Q128 130 120 118 Z" class="fill-white/85 stroke-indigo-200/40 dark:stroke-cyan-200/40"/>
                    </g>
                    <g class="animate-veneer">
                      <path d="M90 58 Q98 46 106 46 Q112 46 112 62 L112 76 Q108 84 100 84 Q92 84 90 76 Z" class="fill-indigo-100/15 dark:fill-cyan-100/15 stroke-indigo-500/50 dark:stroke-cyan-400/50"/>
                    </g>
                    <g class="animate-sparkle">
                      <path d="M65 72 L67 76 L71 76 L68 79 L69 83 L65 80 L61 83 L62 79 L59 76 L63 76 Z" class="fill-indigo-400/50 dark:fill-cyan-300/50"/>
                    </g>
                    <g class="animate-sparkle delay-2">
                      <path d="M140 68 L141 71 L144 71 L142 73 L143 76 L140 74 L137 76 L138 73 L136 71 L139 71 Z" class="fill-indigo-400/40 dark:fill-cyan-300/40"/>
                    </g>
                    <line x1="75" y1="100" x2="78" y2="104" class="stroke-white/25"/>
                    <line x1="102" y1="96" x2="105" y2="100" class="stroke-white/30"/>
                    <line x1="135" y1="96" x2="138" y2="100" class="stroke-white/30"/>
                  </svg>
                )}

                {service.id === 'rehabilitacion-oral' && (
                  <svg class="w-full max-w-sm h-auto text-indigo-500/80 dark:text-cyan-400/80 animate-float-slow transition-colors duration-500" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="0.5">
                    <g class="animate-bridge">
                      <path d="M30 85 Q40 68 52 68 Q62 68 68 85 L68 108 Q62 120 52 120 Q42 120 30 108 Z" class="fill-gray-200/15 stroke-indigo-500/50 dark:stroke-cyan-400/50"/>
                      <path d="M68 78 L132 78" class="stroke-indigo-500/40 dark:stroke-cyan-400/40" stroke-width="1.5"/>
                      <path d="M68 88 Q100 98 132 88" class="stroke-indigo-500/25 dark:stroke-cyan-400/25"/>
                      <path d="M85 78 Q96 58 108 58 Q120 58 125 78 L125 105 Q118 118 106 118 Q94 118 85 105 Z" class="fill-white/10 stroke-indigo-400/50 dark:stroke-cyan-300/50"/>
                      <path d="M132 85 Q142 68 154 68 Q166 68 172 85 L172 108 Q166 120 156 120 Q146 120 132 108 Z" class="fill-gray-200/15 stroke-indigo-500/50 dark:stroke-cyan-400/50"/>
                    </g>
                    <g class="opacity-30">
                      <line x1="52" y1="125" x2="52" y2="145" class="stroke-indigo-500 dark:stroke-cyan-400" stroke-dasharray="3 3"/>
                      <line x1="106" y1="122" x2="106" y2="145" class="stroke-indigo-500 dark:stroke-cyan-400" stroke-dasharray="3 3"/>
                      <line x1="156" y1="125" x2="156" y2="145" class="stroke-indigo-500 dark:stroke-cyan-400" stroke-dasharray="3 3"/>
                    </g>
                    <path d="M45 155 Q105 168 165 155" class="stroke-indigo-500/15 dark:stroke-cyan-400/15" stroke-dasharray="4 2"/>
                    <circle cx="68" cy="78" r="2.5" class="fill-indigo-500/40 dark:fill-cyan-400/40 animate-pulse-dot"/>
                    <circle cx="132" cy="78" r="2.5" class="fill-indigo-500/40 dark:fill-cyan-400/40 animate-pulse-dot delay-1"/>
                  </svg>
                )}

              </div>

              <!-- Right: Text Content -->
              <div class="relative w-full md:w-[45%] h-[55%] md:h-full flex flex-col justify-center px-6 md:px-10 py-6 md:py-0">
                <span class="text-indigo-500/60 dark:text-cyan-400/50 text-xs font-mono tracking-widest mb-4 transition-colors duration-500">0{index + 1}</span>
                <h3 class="text-3xl md:text-4xl lg:text-5xl font-light text-gray-800 dark:text-white mb-6 tracking-tight transition-colors duration-500">
                  {service.title}
                </h3>
                <p class="text-gray-700 dark:text-gray-400 text-base md:text-lg leading-relaxed mb-8 max-w-md transition-colors duration-500">
                  {service.description}
                </p>
                <a
                  href={service.ctaLink}
                  class="inline-flex items-center gap-2 text-gray-700 dark:text-white/80 text-sm font-medium hover:text-indigo-600 dark:hover:text-cyan-400 transition-colors duration-300 group w-fit"
                >
                  <span>{service.ctaText}</span>
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>

            </div>
          </div>
        </div>
      ))}

    </div>

  </div>

  <!-- Indicators -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3">
    {services.map((_, index) => (
      <button
        class={`carousel-indicator w-8 h-[2px] transition-all duration-500 ${index === 0 ? 'bg-gray-700 dark:bg-white' : 'bg-gray-400/50 dark:bg-white/20'}`}
        data-index={index}
        aria-label={`Slide ${index + 1}`}
      ></button>
    ))}
  </div>

</section>

<style>
  /* Border Animation */
  @keyframes border-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .animate-border-spin {
    animation: border-spin 6s linear infinite;
  }

  .border-glow {
    mask-image: radial-gradient(ellipse 50% 50% at center, transparent 35%, black 65%);
    -webkit-mask-image: radial-gradient(ellipse 50% 50% at center, transparent 35%, black 65%);
  }

  /* Float Animations */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes float-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .animate-float-slow {
    animation: float-slow 8s ease-in-out infinite;
  }

  /* Scan Line */
  @keyframes scan-line {
    0%, 100% { opacity: 0.3; transform: translateX(-3px); }
    50% { opacity: 0.8; transform: translateX(3px); }
  }

  .animate-scan-line {
    animation: scan-line 2s ease-in-out infinite;
  }

  .animate-scan-line.delay-1 { animation-delay: 0.3s; }
  .animate-scan-line.delay-2 { animation-delay: 0.6s; }

  /* Hologram */
  @keyframes hologram {
    0%, 100% { opacity: 0.7; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(-4px); }
  }

  .animate-hologram {
    animation: hologram 4s ease-in-out infinite;
  }

  /* Pulse Dot */
  @keyframes pulse-dot {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.9; }
  }

  .animate-pulse-dot {
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .animate-pulse-dot.delay-1 { animation-delay: 0.5s; }

  /* Data Point */
  @keyframes data-point {
    0%, 100% { opacity: 0.2; transform: scale(0.9); }
    50% { opacity: 0.5; transform: scale(1.1); }
  }

  .animate-data-point {
    animation: data-point 3s ease-in-out infinite;
  }

  .animate-data-point.delay-1 { animation-delay: 0.5s; }

  /* Implant */
  @keyframes implant {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  .animate-implant {
    animation: implant 5s ease-in-out infinite;
  }

  /* Guide Line */
  @keyframes guide {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -16; }
  }

  .animate-guide {
    animation: guide 2s linear infinite;
  }

  /* Marker */
  @keyframes marker {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.6; }
  }

  .animate-marker {
    animation: marker 2s ease-in-out infinite;
  }

  /* Smile */
  @keyframes smile {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }

  .animate-smile {
    animation: smile 5s ease-in-out infinite;
  }

  /* Veneer */
  @keyframes veneer {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50% { transform: translateY(8px); opacity: 1; }
  }

  .animate-veneer {
    animation: veneer 4s ease-in-out infinite;
  }

  /* Sparkle */
  @keyframes sparkle {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    50% { opacity: 1; transform: scale(1); }
  }

  .animate-sparkle {
    animation: sparkle 2.5s ease-in-out infinite;
  }

  .animate-sparkle.delay-2 { animation-delay: 0.8s; }

  /* Bridge */
  @keyframes bridge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  .animate-bridge {
    animation: bridge 6s ease-in-out infinite;
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .animate-border-spin,
    .animate-float,
    .animate-float-slow,
    .animate-scan-line,
    .animate-hologram,
    .animate-pulse-dot,
    .animate-data-point,
    .animate-implant,
    .animate-guide,
    .animate-marker,
    .animate-smile,
    .animate-veneer,
    .animate-sparkle,
    .animate-bridge {
      animation: none;
    }

    .border-glow {
      display: none;
    }

    .carousel-card {
      transition: opacity 0.3s ease;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.carousel-card');
    const indicators = document.querySelectorAll('.carousel-indicator');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');

    let currentIndex = 0;
    const totalSlides = cards.length;
    let autoplayInterval: ReturnType<typeof setInterval>;
    const SLIDE_DURATION = 5000; // 5 seconds per slide

    function getRelativeIndex(index: number): number {
      return ((index % totalSlides) + totalSlides) % totalSlides;
    }

    function updateCarousel() {
      const prevIndex = getRelativeIndex(currentIndex - 1);
      const nextIndex = getRelativeIndex(currentIndex + 1);

      cards.forEach((card, index) => {
        const el = card as HTMLElement;

        // Reset all transform/opacity classes
        el.className = 'carousel-card absolute inset-0 transition-all duration-500 ease-out';

        if (index === currentIndex) {
          el.classList.add('opacity-100', 'scale-100', 'z-20', 'translate-x-0');
        } else if (index === prevIndex) {
          el.classList.add('opacity-[0.12]', 'scale-[0.88]', 'z-10', '-translate-x-[75%]');
        } else if (index === nextIndex) {
          el.classList.add('opacity-[0.12]', 'scale-[0.88]', 'z-10', 'translate-x-[75%]');
        } else {
          el.classList.add('opacity-0', 'scale-75', 'z-0', 'translate-x-0');
        }
      });

      indicators.forEach((indicator, index) => {
        if (index === currentIndex) {
          indicator.classList.remove('bg-gray-400/50', 'dark:bg-white/20');
          indicator.classList.add('bg-gray-700', 'dark:bg-white');
        } else {
          indicator.classList.remove('bg-gray-700', 'dark:bg-white');
          indicator.classList.add('bg-gray-400/50', 'dark:bg-white/20');
        }
      });
    }

    function goToSlide(index: number) {
      currentIndex = getRelativeIndex(index);
      updateCarousel();
    }

    function nextSlide() {
      goToSlide(currentIndex + 1);
    }

    function prevSlide() {
      goToSlide(currentIndex - 1);
    }

    function startAutoplay() {
      stopAutoplay();
      autoplayInterval = setInterval(nextSlide, SLIDE_DURATION);
    }

    function stopAutoplay() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
      }
    }

    // Navigation buttons
    prevBtn?.addEventListener('click', () => {
      stopAutoplay();
      prevSlide();
      startAutoplay();
    });

    nextBtn?.addEventListener('click', () => {
      stopAutoplay();
      nextSlide();
      startAutoplay();
    });

    // Indicators
    indicators.forEach((indicator, index) => {
      indicator.addEventListener('click', () => {
        stopAutoplay();
        goToSlide(index);
        startAutoplay();
      });
    });

    // Touch support
    let touchStartX = 0;
    const container = document.querySelector('.carousel-card')?.parentElement;

    container?.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].screenX;
      stopAutoplay();
    }, { passive: true });

    container?.addEventListener('touchend', (e: TouchEvent) => {
      const touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        diff > 0 ? nextSlide() : prevSlide();
      }
      startAutoplay();
    }, { passive: true });

    // Pause on hover
    const section = container?.closest('section');
    section?.addEventListener('mouseenter', stopAutoplay);
    section?.addEventListener('mouseleave', startAutoplay);

    // Initialize
    updateCarousel();
    startAutoplay();
  });
</script>
