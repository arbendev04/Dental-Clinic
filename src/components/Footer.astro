---
const navLinks = [
  { href: '/',          label: 'Inicio'    },
  { href: '/servicios', label: 'Servicios' },
  { href: '/nosotros',  label: 'Nosotros'  },
  { href: '/contacto',  label: 'Contacto'  },
];

const servicios = [
  { href: '/servicios#blanqueamiento', label: 'Blanqueamiento Dental' },
  { href: '/servicios#implantes',      label: 'Implantes Dentales'    },
  { href: '/servicios#ortodoncia',     label: 'Ortodoncia'            },
  { href: '/servicios#general',        label: 'Odontología General'   },
];
---

<footer class="footer">

  <!-- ── Franja editorial CTA ── -->
  <div class="footer-cta-band">
    <div class="footer-inner footer-cta-inner">
      <div class="footer-cta-text">
        <p class="footer-cta-label">Arango Dental Clinic · Benidorm</p>
        <h2 class="footer-cta-headline">
          La sonrisa que imaginas está<br />a una consulta de distancia.
        </h2>
        <p class="footer-cta-sub">
          Visítanos en Benidorm o escríbenos. Nuestro equipo te dedica
          el tiempo y la atención que mereces.
        </p>
      </div>
      <div class="footer-cta-actions">
        <a href="/reservar" class="footer-cta-btn">
          Reservar consulta
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="tel:+34965088282" class="footer-cta-tel">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          96 508 82 82
        </a>
      </div>
    </div>
  </div>

  <!-- ── Cuerpo principal ── -->
  <div class="footer-inner footer-body">
    <div class="footer-grid">

      <!-- Columna marca -->
      <div class="footer-brand">
        <a href="/" aria-label="Arango Dental Clinic — Inicio">
          <img
            src="/img/logo/logo-blanco.png"
            alt="Arango Dental Clinic"
            class="footer-logo"
            width="140"
            height="48"
          />
        </a>
        <p class="footer-tagline">
          Excelencia dental en el corazón<br />del Mediterráneo.
        </p>
        <!-- Horario -->
        <div class="footer-schedule">
          <p class="footer-schedule-row">
            <span class="footer-schedule-label">Lun – Vie</span>
            <span>9:00 – 19:00</span>
          </p>
        </div>
      </div>

      <!-- Columna Clínica -->
      <div class="footer-col">
        <h3 class="footer-col-title">Clínica</h3>
        <ul class="footer-list">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna Servicios -->
      <div class="footer-col">
        <h3 class="footer-col-title">Servicios</h3>
        <ul class="footer-list">
          {servicios.map((s) => (
            <li>
              <a href={s.href} class="footer-link">{s.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna Contacto -->
      <div class="footer-col footer-col-contact">
        <h3 class="footer-col-title">Contacto</h3>
        <ul class="footer-list">
          <li class="footer-address">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span>Avd. Alfonso Puchades 22,<br />Benidorm, Alicante 03501</span>
          </li>
          <li>
            <a href="tel:+34965088282" class="footer-link footer-link-icon">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              96 508 82 82
            </a>
          </li>
          <li>
            <a href="mailto:Arangodentalclinic@gmail.com" class="footer-link footer-link-icon">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              Arangodentalclinic@gmail.com
            </a>
          </li>
        </ul>

        <!-- Redes sociales -->
        <div class="footer-social">
          <a
            href="https://www.facebook.com/p/Arango-Dental-Clinic-61574405870200/"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-link"
            aria-label="Facebook de Arango Dental Clinic"
          >
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/arangodentalclinic/"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-link"
            aria-label="Instagram de Arango Dental Clinic"
          >
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="https://api.whatsapp.com/send?phone=34665886439&text=Hola%20quisiera%20m%C3%A1s%20informaci%C3%B3n"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-link"
            aria-label="WhatsApp de Arango Dental Clinic"
          >
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- ── Línea divisoria ── -->
  <div class="footer-inner">
    <div class="footer-divider"></div>
  </div>

  <!-- ── Barra inferior ── -->
  <div class="footer-inner footer-bottom">
    <p class="footer-copyright">
      © {new Date().getFullYear()} Arango Dental Clinic. Todos los derechos reservados.
    </p>
    <nav class="footer-legal" aria-label="Páginas legales">
      <a href="/politica-privacidad" class="footer-legal-link">Política de Privacidad</a>
      <a href="/terminos-condiciones" class="footer-legal-link">Términos y Condiciones</a>
      <a href="/aviso-legal"          class="footer-legal-link">Aviso Legal</a>
    </nav>
  </div>

</footer>

<style>
  /* ================================================
     FOOTER — siempre oscuro (fondo forestal profundo)
     ================================================ */

  /* Colores del footer — modo CLARO: verde forestal profundo */
  .footer {
    --f-bg:       #0d2219;
    --f-band-bg:  #153328;
    --f-gold:     #C49B38;
    --f-text:     rgba(244, 240, 235, 0.90);
    --f-muted:    rgba(244, 240, 235, 0.45);
    --f-faint:    rgba(244, 240, 235, 0.20);
    --f-border:   rgba(196, 155, 56, 0.15);

    background-color: var(--f-bg);
    color: var(--f-text);
    transition: background-color 0.3s ease;
  }

  /* Modo OSCURO: obsidiana cálida elevada — se distingue del fondo #141210 */
  :global(html.dark) .footer {
    --f-bg:       #252118;   /* bg-tertiary dark — claramente más claro que la página */
    --f-band-bg:  #302B23;   /* borde superior cálido */
    --f-gold:     #D4AF55;   /* gold ligeramente más luminoso sobre oscuro */
    --f-text:     rgba(244, 240, 235, 0.88);
    --f-muted:    rgba(244, 240, 235, 0.42);
    --f-faint:    rgba(244, 240, 235, 0.18);
    --f-border:   rgba(212, 175, 85, 0.18);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 2.5rem;
    padding-right: 2.5rem;
  }

  /* ── Franja CTA ── */
  .footer-cta-band {
    background-color: var(--f-band-bg);
    border-bottom: 1px solid var(--f-border);
  }

  .footer-cta-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .footer-cta-inner {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 4rem;
    }
  }

  .footer-cta-label {
    font-family: "Inter", sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--f-gold);
    margin-bottom: 1rem;
  }

  .footer-cta-headline {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.9rem, 3.5vw, 3rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.2;
    color: var(--f-text);
    margin-bottom: 1rem;
  }

  .footer-cta-sub {
    font-family: "Inter", sans-serif;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--f-muted);
    max-width: 44ch;
  }

  .footer-cta-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-shrink: 0;
  }

  @media (min-width: 480px) {
    .footer-cta-actions {
      flex-direction: row;
      align-items: center;
    }
  }

  @media (min-width: 768px) {
    .footer-cta-actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* Botón CTA principal */
  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--f-bg);
    background-color: var(--f-gold);
    padding: 0.875rem 1.75rem;
    transition: background-color 0.3s ease, color 0.3s ease;
    white-space: nowrap;
  }

  .footer-cta-btn:hover {
    background-color: #A47E2E;
    color: #ffffff;
  }

  /* Teléfono secundario */
  .footer-cta-tel {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Inter", sans-serif;
    font-size: 0.82rem;
    font-weight: 400;
    text-decoration: none;
    color: var(--f-muted);
    transition: color 0.3s ease;
  }

  .footer-cta-tel:hover {
    color: var(--f-text);
  }

  /* ── Cuerpo del footer ── */
  .footer-body {
    padding-top: 4rem;
    padding-bottom: 3rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
      gap: 4rem;
    }
  }

  /* ── Columna marca ── */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .footer-logo {
    height: 2.75rem;
    width: auto;
    display: block;
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }

  .footer-logo:hover {
    opacity: 1;
  }

  .footer-tagline {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.05rem;
    font-weight: 400;
    font-style: italic;
    line-height: 1.55;
    color: var(--f-muted);
  }

  .footer-schedule {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.25rem;
    border-top: 1px solid var(--f-border);
    padding-top: 1rem;
    margin-top: 0.25rem;
  }

  .footer-schedule-row {
    display: flex;
    gap: 0.75rem;
    font-family: "Inter", sans-serif;
    font-size: 0.78rem;
    color: var(--f-muted);
  }

  .footer-schedule-label {
    color: var(--f-faint);
    min-width: 5rem;
  }

  /* ── Columnas de links ── */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-col-title {
    font-family: "Inter", sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--f-gold);
    margin-bottom: 0.25rem;
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    font-family: "Inter", sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    line-height: 1.4;
    color: var(--f-muted);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .footer-link:hover {
    color: var(--f-text);
  }

  /* Links con icono */
  .footer-link-icon {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .footer-link-icon svg {
    flex-shrink: 0;
    margin-top: 0.15em;
    opacity: 0.5;
  }

  /* Dirección (no es link) */
  .footer-address {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: "Inter", sans-serif;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--f-muted);
  }

  .footer-address svg {
    flex-shrink: 0;
    margin-top: 0.2em;
    opacity: 0.5;
  }

  /* ── Redes sociales ── */
  .footer-social {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--f-border);
  }

  .footer-social-link {
    color: var(--f-muted);
    transition: color 0.25s ease, transform 0.25s ease;
    display: flex;
    align-items: center;
  }

  .footer-social-link:hover {
    color: var(--f-gold);
    transform: translateY(-2px);
  }

  /* ── Divisor ── */
  .footer-divider {
    height: 1px;
    background-color: var(--f-border);
    margin-bottom: 1.5rem;
  }

  /* ── Barra inferior ── */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    padding-bottom: 2.5rem;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer-copyright {
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    color: var(--f-faint);
  }

  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.5rem;
  }

  .footer-legal-link {
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    color: var(--f-faint);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .footer-legal-link:hover {
    color: var(--f-muted);
  }
</style>
