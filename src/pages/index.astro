---
import Layout from '../layouts/Layout.astro';
import HeroScroll from '../components/HeroScroll.astro';

const services = [
  {
    icon: 'sparkles',
    title: 'Blanqueamiento Dental',
    description: 'Tratamientos avanzados de blanqueamiento que restauran el brillo natural de tu sonrisa con resultados duraderos.'
  },
  {
    icon: 'shield-check',
    title: 'Implantes Dentales',
    description: 'Soluciones de implantes de última generación que lucen y se sienten como dientes naturales, diseñados para durar.'
  },
  {
    icon: 'smile',
    title: 'Odontología Estética',
    description: 'Transforma tu sonrisa con procedimientos cosméticos de precisión adaptados a tus características únicas.'
  },
];

const stats = [
  { number: '15+', label: 'Años de Experiencia' },
  { number: '5,000+', label: 'Pacientes Felices' },
  { number: '98%', label: 'Tasa de Éxito' },
  { number: '24/7', label: 'Atención de Emergencias' },
];

const testimonials = [
  {
    quote: 'El cuidado y la atención al detalle en Aurum Dental es verdaderamente excepcional. Mi sonrisa nunca había lucido mejor.',
    author: 'María García'
  },
  {
    quote: 'Profesionales, corteses y genuinamente atentos. Hicieron que lo que pensé sería un proceso difícil fuera completamente libre de estrés.',
    author: 'Carlos Martínez'
  },
  {
    quote: 'Desde el momento en que entré, supe que estaba en manos expertas. Los resultados superaron todas mis expectativas.',
    author: 'Laura Fernández'
  },
];
---

<Layout title="Inicio">
  <!-- Hero Section -->
  <HeroScroll />

  <!-- Services Section -->
  <section class="px-5 lg:px-20 py-16 md:py-24 lg:py-28 transition-colors" style="background-color: var(--bg-secondary);">
    <div class="container mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-10 md:mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-px" style="background-color: var(--gold-500);"></div>
          <span class="text-[0.65rem] tracking-[0.2em] uppercase font-medium" style="color: var(--gold-600);">
            Nuestros Servicios
          </span>
          <div class="w-8 h-px" style="background-color: var(--gold-500);"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal" style="font-family: 'Cormorant Garamond', serif; color: var(--text-primary);">
          Cuidado Profesional a Tu Medida
        </h2>
      </div>

      <!-- Services Grid -->
      <div class="grid md:grid-cols-3 gap-4 md:gap-6">
        {services.map((service) => (
          <div class="p-6 md:p-10 transition-all duration-300 hover:translate-y-[-4px]" style="background-color: var(--bg-primary); border: 1px solid var(--border-primary);">
            <div class="w-12 h-12 md:w-14 md:h-14 flex items-center justify-center mb-5" style="background-color: var(--teal-100);">
              <svg class="w-6 h-6 md:w-7 md:h-7" style="color: var(--teal-600);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {service.icon === 'sparkles' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                )}
                {service.icon === 'shield-check' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                )}
                {service.icon === 'smile' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                )}
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-semibold mb-3 md:mb-5" style="font-family: 'Cormorant Garamond', serif; color: var(--text-primary);">{service.title}</h3>
            <p class="text-sm md:text-[15px] mb-5 md:mb-6" style="color: var(--text-secondary); line-height: 1.7;">{service.description}</p>
            <a href="/servicios" class="inline-flex items-center gap-2 text-sm font-medium transition-opacity hover:opacity-60" style="color: var(--gold-600);">
              <span>Saber Más</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="px-5 lg:px-20 py-16 md:py-24 transition-colors" style="background-color: var(--bg-primary);">
    <div class="container mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-10 md:mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-px" style="background-color: var(--gold-500);"></div>
          <span class="text-[0.65rem] tracking-[0.2em] uppercase font-medium" style="color: var(--gold-600);">
            Excelencia en Números
          </span>
          <div class="w-8 h-px" style="background-color: var(--gold-500);"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal" style="font-family: 'Cormorant Garamond', serif; color: var(--text-primary);">
          Un Legado de Excelencia
        </h2>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-2 md:flex md:flex-wrap md:justify-around gap-8 md:gap-12">
        {stats.map((stat) => (
          <div class="flex flex-col items-center gap-2">
            <div class="text-4xl md:text-5xl font-light" style="font-family: 'Cormorant Garamond', serif; color: var(--teal-600);">
              {stat.number}
            </div>
            <div class="text-[11px] md:text-[13px] font-medium uppercase text-center" style="color: var(--text-secondary); letter-spacing: 0.15em;">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="px-5 lg:px-20 py-16 md:py-24 transition-colors" style="background-color: var(--bg-secondary);">
    <div class="container mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-10 md:mb-16">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-8 h-px" style="background-color: var(--gold-500);"></div>
          <span class="text-[0.65rem] tracking-[0.2em] uppercase font-medium" style="color: var(--gold-600);">
            Testimonios
          </span>
          <div class="w-8 h-px" style="background-color: var(--gold-500);"></div>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal" style="font-family: 'Cormorant Garamond', serif; color: var(--text-primary);">
          Lo Que Dicen Nuestros Pacientes
        </h2>
      </div>

      <!-- Testimonials Grid -->
      <div class="grid md:grid-cols-3 gap-4 md:gap-6">
        {testimonials.map((testimonial) => (
          <div class="p-6 md:p-10 transition-all duration-300" style="background-color: var(--bg-primary); border: 1px solid var(--border-primary);">
            <p class="text-base md:text-lg italic mb-5 md:mb-6" style="font-family: 'Cormorant Garamond', serif; color: var(--text-primary); line-height: 1.7;">
              "{testimonial.quote}"
            </p>
            <div class="flex items-center gap-3">
              <div class="w-6 h-px" style="background-color: var(--gold-500);"></div>
              <span class="text-[12px] md:text-[13px] font-medium tracking-wider" style="color: var(--text-secondary); letter-spacing: 0.08em;">
                {testimonial.author}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner Section -->
  <section class="cta-banner px-5 lg:px-20 py-14 md:py-20 flex items-center justify-center transition-colors">
    <div class="container mx-auto text-center max-w-3xl">
      <h2 class="cta-banner-title text-3xl md:text-4xl lg:text-5xl font-normal mb-5 md:mb-6" style="font-family: 'Cormorant Garamond', serif;">
        ¿Listo para Experimentar la Diferencia?
      </h2>
      <p class="cta-banner-sub text-sm md:text-base mb-7 md:mb-10" style="line-height: 1.75; max-width: 480px; margin-left: auto; margin-right: auto;">
        Reserva tu consulta hoy y descubre por qué los pacientes más exigentes eligen Aurum Dental.
      </p>
      <a
        href="/reservar"
        class="cta-banner-btn inline-block px-8 md:px-10 py-3.5 md:py-4 text-sm md:text-[15px] font-medium tracking-wider transition-all duration-300"
        style="letter-spacing: 0.1em;"
      >
        Reservar Tu Cita
      </a>
    </div>
  </section>

  <style>
    /* CTA Banner — modo claro */
    .cta-banner {
      background-color: var(--bg-tertiary);
    }
    .cta-banner-title {
      color: var(--teal-700);
    }
    .cta-banner-sub {
      color: var(--text-secondary);
    }
    .cta-banner-btn {
      background-color: transparent;
      color: #153328;
      border: 1px solid rgba(21, 51, 40, 0.65);
    }
    .cta-banner-btn:hover {
      background-color: #153328;
      color: #ffffff;
      border-color: #153328;
    }

    /* Modo oscuro: fondo dark de la landing */
    :global(html.dark) .cta-banner {
      background-color: #141210;
    }
    :global(html.dark) .cta-banner-title {
      color: rgba(244, 240, 235, 0.95);
    }
    :global(html.dark) .cta-banner-sub {
      color: rgba(244, 240, 235, 0.55);
    }
    :global(html.dark) .cta-banner-btn {
      background-color: transparent;
      color: rgba(244, 240, 235, 0.85);
      border: 1px solid rgba(244, 240, 235, 0.30);
    }
    :global(html.dark) .cta-banner-btn:hover {
      background-color: #D4AF55;
      color: #141210;
      border-color: #D4AF55;
    }
  </style>
</Layout>
