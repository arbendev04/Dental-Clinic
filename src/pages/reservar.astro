---
import Layout from '../layouts/Layout.astro';

const pasos = [
  {
    num: '01',
    titulo: 'Contacta con nosotros',
    texto: 'Llama, envía un WhatsApp o rellena el formulario de contacto. Te responderemos en menos de 24h.',
  },
  {
    num: '02',
    titulo: 'Valoración inicial gratuita',
    texto: 'En tu primera visita evaluamos tu caso sin compromiso y te explicamos las opciones de tratamiento.',
  },
  {
    num: '03',
    titulo: 'Plan personalizado',
    texto: 'Diseñamos un plan adaptado a tus necesidades, tiempos y presupuesto. Sin sorpresas.',
  },
];
---

<Layout title="Reservar Cita" description="Reserva tu cita en Arango Dental Clinic - Clínica odontológica de alta gama en Benidorm">

  <!-- ── Hero ── -->
  <section class="rsv-hero" data-scroll-hero>
    <div class="rsv-container rsv-hero-inner">
      <p class="rsv-label">Arango Dental Clinic</p>
      <h1 class="rsv-hero-title">Tu primera visita<br>es <em>gratuita</em></h1>
      <p class="rsv-hero-sub">
        Agenda tu valoración sin costo y da el primer paso hacia la sonrisa que mereces.
      </p>
      <div class="rsv-hero-actions">
        <a href="tel:+34965088282" class="rsv-btn rsv-btn-solid">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          Llamar Ahora
        </a>
        <a href="https://api.whatsapp.com/send?phone=34665886439&text=Hola,%20quisiera%20reservar%20una%20cita" target="_blank" rel="noopener noreferrer" class="rsv-btn rsv-btn-outline">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- ── Cómo funciona ── -->
  <section class="rsv-pasos-section">
    <div class="rsv-container">
      <div class="rsv-section-header reveal-up">
        <p class="rsv-label">Cómo funciona</p>
        <h2 class="rsv-section-title">Tres pasos hacia tu nueva sonrisa</h2>
      </div>
      <div class="rsv-pasos-grid">
        {pasos.map((paso, i) => (
          <div class="rsv-paso reveal-up" style={`--reveal-delay: ${i * 100}ms`}>
            <span class="rsv-paso-num">{paso.num}</span>
            <h3 class="rsv-paso-titulo">{paso.titulo}</h3>
            <p class="rsv-paso-texto">{paso.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Info adicional ── -->
  <section class="rsv-info-section">
    <div class="rsv-container rsv-info-grid">
      <!-- Horario -->
      <div class="rsv-info-card reveal-up">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--gold-500);">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="rsv-info-title">Horario de atención</h3>
        <p class="rsv-info-text">Lunes a Viernes: 9:00 – 19:00</p>
        <p class="rsv-info-text">Sábados: 9:00 – 14:00</p>
      </div>

      <!-- Ubicación -->
      <div class="rsv-info-card reveal-up" style="--reveal-delay: 100ms">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--gold-500);">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
        <h3 class="rsv-info-title">Ubicación</h3>
        <p class="rsv-info-text">Avd. Alfonso Puchades 22</p>
        <p class="rsv-info-text">Benidorm, Alicante 03501</p>
      </div>

      <!-- Contacto alternativo -->
      <div class="rsv-info-card reveal-up" style="--reveal-delay: 200ms">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--gold-500);">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <h3 class="rsv-info-title">¿Prefieres escribirnos?</h3>
        <a href="/contacto" class="rsv-info-link">Ir al formulario de contacto →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Layout ── */
  .rsv-container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  /* ── Hero ── */
  .rsv-hero {
    background-color: #0d2219;
    padding: 8rem 0 5rem;
    text-align: center;
  }

  :global(html.dark) .rsv-hero {
    background-color: #0d2219;
  }

  .rsv-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .rsv-label {
    font-family: "Inter", sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C49B38;
  }

  :global(html.dark) .rsv-label {
    color: #D4AF55;
  }

  .rsv-hero-title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.1;
    color: rgba(244, 240, 235, 0.95);
    margin: 0;
  }

  .rsv-hero-title em {
    color: #C49B38;
    font-style: italic;
  }

  .rsv-hero-sub {
    font-family: "Inter", sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(244, 240, 235, 0.50);
    max-width: 48ch;
    margin: 0;
  }

  .rsv-hero-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  @media (min-width: 480px) {
    .rsv-hero-actions { flex-direction: row; }
  }

  /* ── Botones ── */
  .rsv-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.875rem 2rem;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    white-space: nowrap;
  }

  .rsv-btn-solid {
    background-color: #C49B38;
    color: #0d2219;
    border: 1px solid #C49B38;
  }

  .rsv-btn-solid:hover {
    background-color: transparent;
    color: rgba(244, 240, 235, 0.85);
    border-color: rgba(244, 240, 235, 0.35);
  }

  :global(html.dark) .rsv-btn-solid {
    background-color: #D4AF55;
    color: #141210;
    border-color: #D4AF55;
  }

  :global(html.dark) .rsv-btn-solid:hover {
    background-color: transparent;
    color: rgba(244, 240, 235, 0.85);
    border-color: rgba(244, 240, 235, 0.35);
  }

  .rsv-btn-outline {
    background-color: transparent;
    color: rgba(244, 240, 235, 0.85);
    border: 1px solid rgba(244, 240, 235, 0.35);
  }

  .rsv-btn-outline:hover {
    background-color: rgba(244, 240, 235, 0.1);
    border-color: rgba(244, 240, 235, 0.6);
  }

  /* ── Pasos ── */
  .rsv-pasos-section {
    background-color: var(--bg-primary);
    padding: 5rem 0;
  }

  .rsv-section-header {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .rsv-section-title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    font-style: italic;
    color: var(--text-primary);
    margin: 0;
  }

  .rsv-pasos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .rsv-pasos-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }
  }

  .rsv-paso {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    border: 1px solid var(--border-primary);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .rsv-paso:hover {
    border-color: var(--border-secondary);
    transform: translateY(-4px);
  }

  .rsv-paso-num {
    font-family: "Cormorant Garamond", serif;
    font-size: 2.5rem;
    font-weight: 300;
    font-style: italic;
    color: var(--gold-500);
    line-height: 1;
  }

  .rsv-paso-titulo {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0;
  }

  .rsv-paso-texto {
    font-family: "Inter", sans-serif;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ── Info cards ── */
  .rsv-info-section {
    background-color: var(--bg-secondary);
    padding: 4rem 0;
  }

  :global(html.dark) .rsv-info-section {
    background-color: #141210;
  }

  .rsv-info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .rsv-info-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .rsv-info-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    background-color: var(--bg-primary);
    border: 1px solid var(--border-primary);
  }

  :global(html.dark) .rsv-info-card {
    background-color: var(--bg-secondary);
  }

  .rsv-info-title {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0;
  }

  .rsv-info-text {
    font-family: "Inter", sans-serif;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .rsv-info-link {
    font-family: "Inter", sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--teal-600);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .rsv-info-link:hover {
    opacity: 0.7;
  }

  /* ── Reveal ── */
  .reveal-up {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }

  .reveal-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  (function () {
    const els = document.querySelectorAll('.reveal-up');
    if (!els.length) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    els.forEach((el) => io.observe(el));
  })();
</script>
