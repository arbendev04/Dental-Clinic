---
import Layout from '../layouts/Layout.astro';

const equipo = [
  {
    nombre: 'Dr. Sebastián Arango',
    especialidad: 'Director · Implantología',
    descripcion: 'Fundador y director de Arango Dental Clinic. Especialista en implantología y rehabilitación oral, con formación en las técnicas más avanzadas de odontología digital.',
    principal: true,
  },
  {
    nombre: 'Ana Delheil',
    especialidad: 'Higienista Dental · Periodoncia',
    descripcion: 'Especialista en higiene bucodental y periodoncia. Comprometida con la prevención y el mantenimiento de la salud oral de cada paciente.',
    principal: false,
  },
  {
    nombre: 'Natalia Svetlozarova',
    especialidad: 'Estética Dental',
    descripcion: 'Experta en odontología estética y rehabilitadora. Especializada en diseño de sonrisa, carillas y tratamientos de composite de alta precisión.',
    principal: false,
  },
  {
    nombre: 'Sandra Romero',
    especialidad: 'Ortodoncia',
    descripcion: 'Especialista en ortodoncia con brackets y alineadores invisibles. Transforma sonrisas con planificación personalizada para cada paciente.',
    principal: false,
  },
];

const stats = [
  { valor: '+15', label: 'años de experiencia' },
  { valor: '+5000', label: 'pacientes atendidos' },
  { valor: '98%', label: 'satisfacción' },
  { valor: '6', label: 'especialidades' },
];

const valores = [
  {
    num: '01',
    titulo: 'Confianza',
    texto: 'Construimos relaciones basadas en la transparencia y la honestidad. Cada diagnóstico y cada plan de tratamiento se explica con claridad antes de comenzar.',
  },
  {
    num: '02',
    titulo: 'Excelencia',
    texto: 'Buscamos la perfección en cada procedimiento. Formación continua, tecnología de última generación y protocolos clínicos de máxima precisión.',
  },
  {
    num: '03',
    titulo: 'Empatía',
    texto: 'Entendemos tus miedos y tus expectativas. Te acompañamos en cada paso del tratamiento con cercanía, paciencia y cuidado real.',
  },
];
---

<Layout title="Nosotros" description="Conoce al equipo profesional de Arango Dental Clinic">

  <!-- ── HERO ── -->
  <section class="nos-hero" data-scroll-hero>
    <img
      src="/img/banner/banner-arango.webp"
      alt="Fachada de Arango Dental Clinic, Benidorm"
      class="nos-hero-img"
      fetchpriority="high"
      decoding="async"
    />
    <div class="nos-hero-overlay" aria-hidden="true"></div>
    <div class="nos-container nos-hero-inner">
      <div class="nos-hero-content reveal-up">
        <p class="nos-label">El equipo</p>
        <h1 class="nos-hero-title">
          Detrás de cada<br>
          <em>tratamiento,</em><br>
          hay un gran equipo
        </h1>
        <div class="nos-hero-line"></div>
        <p class="nos-hero-sub">
          Profesionales apasionados por la salud bucal, comprometidos con tu bienestar y con la excelencia en cada tratamiento.
        </p>
      </div>
    </div>
    <div class="nos-hero-scroll-hint" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- ── MANIFIESTO ── -->
  <section class="nos-manifiesto">
    <div class="nos-container">
      <div class="nos-quote reveal-up">
        <span class="nos-quote-mark" aria-hidden="true">"</span>
        <blockquote class="nos-quote-text">
          Cada tratamiento es una promesa.<br>Cada paciente, una historia que merece el mejor cuidado.
        </blockquote>
        <cite class="nos-quote-cite">— Dr. Sebastián Arango, Director</cite>
      </div>
    </div>
  </section>

  <!-- ── HISTORIA + STATS ── -->
  <section class="nos-historia-section">
    <div class="nos-container nos-historia-grid">

      <!-- Texto -->
      <div class="nos-historia-text reveal-up">
        <p class="nos-label" style="margin-bottom: 1rem;">Nuestra historia</p>
        <h2 class="nos-section-title">Una clínica construida<br>sobre la confianza</h2>
        <p class="nos-body">
          Arango Dental Clinic nació de la convicción de que cada paciente merece una atención personalizada, honesta y de la máxima calidad. Desde nuestra apertura en Benidorm, hemos atendido a miles de pacientes que depositan su confianza en nosotros.
        </p>
        <p class="nos-body">
          Contamos con tecnología de última generación —escáner intraoral 3D, radiografía digital de baja dosis y diseño de sonrisa digital— y un equipo de profesionales siempre actualizados con las últimas técnicas del sector.
        </p>
      </div>

      <!-- Stats -->
      <div class="nos-stats reveal-up" style="--reveal-delay: 100ms;">
        {stats.map((s) => (
          <div class="nos-stat-item">
            <span class="nos-stat-valor" data-target={s.valor}>{s.valor}</span>
            <span class="nos-stat-label">{s.label}</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── VALORES ── -->
  <section class="nos-valores-section">
    <div class="nos-container">
      <div class="nos-valores-header reveal-up">
        <p class="nos-label">Lo que nos mueve</p>
        <h2 class="nos-section-title">Nuestros valores</h2>
      </div>
      <div class="nos-valores-list">
        {valores.map((v, i) => (
          <div class="nos-valor-item reveal-up" style={`--reveal-delay: ${i * 80}ms`}>
            <span class="nos-valor-num">{v.num}</span>
            <div class="nos-valor-body">
              <h3 class="nos-valor-title">{v.titulo}</h3>
              <p class="nos-valor-texto">{v.texto}</p>
            </div>
            <div class="nos-valor-line"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── EQUIPO ── -->

  <!-- Director — sección editorial propia -->
  <section class="nos-director-section">
    <div class="nos-director-split reveal-up">

      <!-- Imagen -->
      <div class="nos-director-img-wrap">
        <img
          src="/img/sebas.webp"
          alt="Dr. Sebastián Arango, director de Arango Dental Clinic"
          class="nos-director-img"
          loading="lazy"
          decoding="async"
        />
        <div class="nos-director-img-overlay" aria-hidden="true"></div>
      </div>

      <!-- Texto -->
      <div class="nos-director-text">
        <p class="nos-label">Director de la clínica</p>
        <h2 class="nos-director-heading">Dr. Sebastián<br>Arango</h2>
        <p class="nos-director-role-tag">Implantología · Rehabilitación Oral · Odontología Digital</p>
        <p class="nos-director-bio">
          Fundador y director de Arango Dental Clinic. Especialista en implantología y rehabilitación oral, con formación en las técnicas más avanzadas de odontología digital.
        </p>
        <p class="nos-director-bio">
          Su visión de una clínica cercana, honesta y de alta excelencia es la base de todo lo que hacemos cada día en Benidorm.
        </p>
        <div class="nos-director-divider" aria-hidden="true"></div>
        <p class="nos-director-quote">"Cada paciente merece sentir que está en las mejores manos."</p>
      </div>

    </div>
  </section>

  <!-- Equipo — las 3 compañeras -->
  <section class="nos-equipo-section">
    <div class="nos-container">
      <div class="nos-equipo-header reveal-up">
        <p class="nos-label">Nuestro equipo</p>
        <h2 class="nos-section-title">Las personas detrás<br>de cada sonrisa</h2>
      </div>

      <div class="nos-team-grid">
        <!-- Ana Deltell -->
        <div class="nos-member-card reveal-up" style="--reveal-delay: 0ms">
          <div class="nos-member-img-wrap">
            <img
              src="/img/Ana-Deltell.webp"
              alt="Ana Deltell, higienista dental"
              class="nos-member-img"
              style="object-position: center top;"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="nos-member-info">
            <p class="nos-member-role">Higienista Dental · Periodoncia</p>
            <h3 class="nos-member-name">Ana Deltell</h3>
            <p class="nos-member-bio">Especialista en higiene bucodental y periodoncia. Comprometida con la prevención y el mantenimiento de la salud oral de cada paciente.</p>
          </div>
        </div>

        <!-- Natalia Svetlozarova -->
        <div class="nos-member-card reveal-up" style="--reveal-delay: 80ms">
          <div class="nos-member-img-wrap">
            <img
              src="/img/Natalia_Svetlozarova.webp"
              alt="Natalia Svetlozarova, estética dental"
              class="nos-member-img"
              style="object-position: center 15%;"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="nos-member-info">
            <p class="nos-member-role">Estética Dental</p>
            <h3 class="nos-member-name">Natalia Svetlozarova</h3>
            <p class="nos-member-bio">Experta en odontología estética y rehabilitadora. Especializada en diseño de sonrisa, carillas y tratamientos de composite de alta precisión.</p>
          </div>
        </div>

        <!-- Sandra Romero -->
        <div class="nos-member-card reveal-up" style="--reveal-delay: 160ms">
          <div class="nos-member-img-wrap">
            <img
              src="/img/Sandra_Romero.webp"
              alt="Sandra Romero, ortodoncia"
              class="nos-member-img"
              style="object-position: center 10%;"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="nos-member-info">
            <p class="nos-member-role">Ortodoncia</p>
            <h3 class="nos-member-name">Sandra Romero</h3>
            <p class="nos-member-bio">Especialista en ortodoncia con brackets y alineadores invisibles. Transforma sonrisas con planificación personalizada para cada paciente.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="nos-cta-section">
    <div class="nos-container nos-cta-inner reveal-up">
      <p class="nos-label nos-cta-label">Primer paso</p>
      <h2 class="nos-cta-title">Empieza con una valoración<br><em>sin costo</em></h2>
      <p class="nos-cta-sub">Agenda tu primera visita y descubre cómo podemos transformar tu sonrisa.</p>
      <div class="nos-cta-actions">
        <a href="/contacto" class="nos-btn nos-btn-outline">Contactar</a>
        <a href="/reservar"  class="nos-btn nos-btn-solid">Reservar Cita</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ─────────────────────────────────────────
   BASE
───────────────────────────────────────── */
.nos-container {
  max-width: 1200px;
  margin: 0 auto;
  padding-left: 2rem;
  padding-right: 2rem;
}

.nos-label {
  font-family: "Inter", sans-serif;
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #C49B38;
  display: block;
}

:global(html.dark) .nos-label { color: #D4AF55; }

.nos-section-title {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 300;
  line-height: 1.15;
  color: var(--text-primary);
  margin: 0.5rem 0 0;
}

.nos-body {
  font-family: "Inter", sans-serif;
  font-size: 0.95rem;
  line-height: 1.8;
  color: var(--text-secondary);
  margin: 0 0 1rem;
}

/* ─────────────────────────────────────────
   REVEAL ANIMATIONS
───────────────────────────────────────── */
.reveal-up {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.65s ease, transform 0.65s ease;
  transition-delay: var(--reveal-delay, 0ms);
}

.reveal-up.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ─────────────────────────────────────────
   HERO
───────────────────────────────────────── */
.nos-hero {
  position: relative;
  min-height: 92vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background-color: #0d2219;
}

/* Imagen de fondo */
.nos-hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  display: block;
}

/* Overlay: texto legible a la izquierda, imagen respira a la derecha */
.nos-hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(
      105deg,
      rgba(6, 18, 10, 0.82) 0%,
      rgba(6, 18, 10, 0.52) 45%,
      rgba(6, 18, 10, 0.18) 100%
    );
}

:global(html.dark) .nos-hero-overlay {
  background:
    linear-gradient(
      105deg,
      rgba(4, 12, 7, 0.88) 0%,
      rgba(4, 12, 7, 0.58) 45%,
      rgba(4, 12, 7, 0.22) 100%
    );
}

.nos-hero-inner {
  position: relative;
  z-index: 1;
  padding-top: 7rem;
  padding-bottom: 6rem;
}

.nos-hero-content {
  max-width: 640px;
}

.nos-hero-title {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(2.8rem, 6vw, 5.2rem);
  font-weight: 300;
  line-height: 1.1;
  color: rgba(244, 240, 235, 0.95);
  margin: 0.75rem 0 1.5rem;
}

.nos-hero-title em {
  font-style: italic;
  color: #C49B38;
}

.nos-hero-line {
  width: 3rem;
  height: 1px;
  background-color: rgba(196, 155, 56, 0.5);
  margin-bottom: 1.5rem;
}

.nos-hero-sub {
  font-family: "Inter", sans-serif;
  font-size: 0.975rem;
  line-height: 1.75;
  color: rgba(244, 240, 235, 0.55);
  max-width: 48ch;
}

/* scroll hint */
.nos-hero-scroll-hint {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
}

.nos-hero-scroll-hint span {
  display: block;
  width: 1px;
  height: 3.5rem;
  background: linear-gradient(to bottom, rgba(196,155,56,0.6), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; transform: scaleY(1); }
  50%       { opacity: 0.9; transform: scaleY(0.6); }
}

/* ─────────────────────────────────────────
   MANIFIESTO
───────────────────────────────────────── */
.nos-manifiesto {
  background-color: var(--bg-primary);
  padding: 6rem 0;
  border-bottom: 1px solid var(--border-primary);
}

.nos-quote {
  position: relative;
  max-width: 820px;
  margin: 0 auto;
  text-align: center;
  padding: 0 1rem;
}

.nos-quote-mark {
  display: block;
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(6rem, 14vw, 12rem);
  line-height: 0.7;
  color: #C49B38;
  opacity: 0.18;
  margin-bottom: -1.5rem;
  user-select: none;
}

:global(html.dark) .nos-quote-mark { color: #D4AF55; }

.nos-quote-text {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(1.6rem, 3.5vw, 2.6rem);
  font-weight: 300;
  font-style: italic;
  line-height: 1.4;
  color: var(--text-primary);
  margin: 0 0 1.5rem;
}

.nos-quote-cite {
  font-family: "Inter", sans-serif;
  font-size: 0.75rem;
  font-style: normal;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-tertiary);
}

/* ─────────────────────────────────────────
   HISTORIA + STATS
───────────────────────────────────────── */
.nos-historia-section {
  background-color: var(--bg-secondary);
  padding: 6rem 0;
}

.nos-historia-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4rem;
}

@media (min-width: 900px) {
  .nos-historia-grid {
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 6rem;
  }
}

.nos-historia-text { display: flex; flex-direction: column; gap: 0; }
.nos-historia-text .nos-section-title { margin-bottom: 1.75rem; }

.nos-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

.nos-stat-item {
  padding: 2.5rem 2rem;
  border: 1px solid var(--border-primary);
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  transition: background-color 0.3s ease;
}

.nos-stat-item:hover { background-color: var(--bg-tertiary); }

.nos-stat-valor {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(2.4rem, 5vw, 3.6rem);
  font-weight: 300;
  font-style: italic;
  color: var(--text-primary);
  line-height: 1;
}

.nos-stat-label {
  font-family: "Inter", sans-serif;
  font-size: 0.75rem;
  font-weight: 400;
  color: var(--text-tertiary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────
   VALORES
───────────────────────────────────────── */
.nos-valores-section {
  background-color: var(--bg-primary);
  padding: 6rem 0;
}

.nos-valores-header {
  margin-bottom: 3.5rem;
}

.nos-valores-list {
  display: flex;
  flex-direction: column;
}

.nos-valor-item {
  position: relative;
  display: grid;
  grid-template-columns: 4rem 1fr;
  gap: 2rem;
  padding: 2.5rem 0;
  cursor: default;
}

.nos-valor-line {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1px;
  background-color: var(--border-primary);
  transform-origin: left;
  transition: background-color 0.4s ease;
}

.nos-valor-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 1px;
  background-color: #C49B38;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

:global(html.dark) .nos-valor-item::after { background-color: #D4AF55; }

.nos-valor-item:hover::after { width: 100%; }

.nos-valor-num {
  font-family: "Cormorant Garamond", serif;
  font-size: 0.9rem;
  font-style: italic;
  color: #C49B38;
  padding-top: 0.2rem;
  line-height: 1;
}

:global(html.dark) .nos-valor-num { color: #D4AF55; }

.nos-valor-body { display: flex; flex-direction: column; gap: 0.75rem; }

.nos-valor-title {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 400;
  color: var(--text-primary);
  margin: 0;
  transition: color 0.3s ease;
}

.nos-valor-item:hover .nos-valor-title { color: var(--teal-600); }

.nos-valor-texto {
  font-family: "Inter", sans-serif;
  font-size: 0.9rem;
  line-height: 1.75;
  color: var(--text-secondary);
  max-width: 68ch;
  margin: 0;
}

/* ─────────────────────────────────────────
   DIRECTOR — sección editorial
───────────────────────────────────────── */
.nos-director-section {
  background-color: var(--bg-primary);
  overflow: hidden;
}

.nos-director-split {
  display: grid;
  grid-template-columns: 1fr;
  min-height: 680px;
}

@media (min-width: 900px) {
  .nos-director-split {
    grid-template-columns: 1fr 1fr;
  }
}

/* Imagen */
.nos-director-img-wrap {
  position: relative;
  overflow: hidden;
  min-height: 420px;
}

@media (min-width: 900px) {
  .nos-director-img-wrap { min-height: 680px; }
}

.nos-director-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.nos-director-img-wrap:hover .nos-director-img {
  transform: scale(1.03);
}

.nos-director-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    transparent 60%,
    var(--bg-primary) 100%
  );
  pointer-events: none;
}

@media (max-width: 899px) {
  .nos-director-img-overlay {
    background: linear-gradient(
      to bottom,
      transparent 60%,
      var(--bg-primary) 100%
    );
  }
}

/* Texto */
.nos-director-text {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 1rem;
  padding: 3.5rem 3rem 3.5rem 2.5rem;
}

@media (min-width: 900px) {
  .nos-director-text { padding: 5rem 4rem; }
}

.nos-director-heading {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(2.6rem, 5vw, 4rem);
  font-weight: 300;
  line-height: 1.05;
  color: var(--text-primary);
  margin: 0.4rem 0 0.25rem;
}

.nos-director-role-tag {
  font-family: "Inter", sans-serif;
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--teal-600);
  margin: 0 0 0.5rem;
}

.nos-director-bio {
  font-family: "Inter", sans-serif;
  font-size: 0.925rem;
  line-height: 1.8;
  color: var(--text-secondary);
  margin: 0;
  max-width: 52ch;
}

.nos-director-divider {
  width: 2.5rem;
  height: 1px;
  background-color: #C49B38;
  opacity: 0.55;
  margin: 0.5rem 0;
}

:global(html.dark) .nos-director-divider { background-color: #D4AF55; }

.nos-director-quote {
  font-family: "Cormorant Garamond", serif;
  font-size: 1.2rem;
  font-style: italic;
  font-weight: 400;
  color: var(--text-tertiary);
  margin: 0;
  max-width: 46ch;
}

/* ─────────────────────────────────────────
   EQUIPO — grid 3 miembros
───────────────────────────────────────── */
.nos-equipo-section {
  background-color: var(--bg-secondary);
  padding: 6rem 0;
}

.nos-equipo-header {
  margin-bottom: 3.5rem;
}

.nos-team-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 640px) {
  .nos-team-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .nos-team-grid { grid-template-columns: repeat(3, 1fr); }
}

.nos-member-card {
  display: flex;
  flex-direction: column;
  background-color: var(--bg-primary);
  border: 1px solid var(--border-primary);
  overflow: hidden;
  transition: border-color 0.3s ease, transform 0.3s ease;
}

.nos-member-card:hover {
